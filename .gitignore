# Build output
bin/
obj/

# .NET
*.user
*.suo
.vs/

# Local secrets — never commit environment-specific overrides
appsettings.Development.json
appsettings.Local.json

# SQLite database files (runtime content cache, not source-controlled)
*.db
*.db-shm
*.db-wal

# Claude — local config, secrets, cache
.claude/
# skills/ at repo root is git-tracked; .claude/skills is a junction pointing here
# so Claude Code discovers skills at its expected path without duplicating files.