@using AiPulse.Application.DTOs

<div class="trending-card">
    <a href="@Item.Url" target="_blank" rel="noopener noreferrer">@Item.Title</a>
    <div class="trending-card__meta">
        <span class="trending-card__source">@Item.SourceName</span>
        <span class="trending-card__score" title="Trend score">@((int)Item.TrendScore)</span>
    </div>
    <div class="trending-card__stats">
        <span title="Upvotes">@Item.Upvotes ▲</span>
        <span title="Comments">@Item.CommentCount 💬</span>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public TrendingItemDto Item { get; set; } = null!;
}
