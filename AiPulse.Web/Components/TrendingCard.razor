@using AiPulse.Application.DTOs

<a class="trending-card" href="@Item.Url" target="_blank" rel="noopener noreferrer">
    <div class="trending-card__title">@Item.Title</div>
    <div class="trending-card__meta">
        <span class="@BadgeClass">@Item.SourceName</span>
        <span class="trending-card__score" title="Trend score">@((int)Item.TrendScore)</span>
    </div>
    <div class="trending-card__stats">
        <span title="Upvotes">@Item.Upvotes ▲</span>
        <span title="Comments">@Item.CommentCount 💬</span>
    </div>
</a>

@code {
    [Parameter, EditorRequired] public TrendingItemDto Item { get; set; } = null!;

    private string BadgeClass => Item.SourceName switch
    {
        "Reddit"      => "source-badge source-badge--reddit",
        "HackerNews"  => "source-badge source-badge--hackernews",
        "ProductHunt" => "source-badge source-badge--producthunt",
        _             => "source-badge"
    };
}
