@using AiPulse.Application.DTOs

@if (Row.Items.Any())
{
    <section class="trending-row">
        <div class="trending-row__header">
            <h2>@Heading</h2>
            <a href="@SourceHref" class="trending-row__see-all">See all →</a>
        </div>
        <div class="trending-row__scroll">
            @foreach (var item in Row.Items)
            {
                <TrendingCard Item="item" />
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public TrendingRowDto Row { get; set; } = null!;

    private string Heading => Row.ContentType switch
    {
        "Reddit"        => "🔴 Reddit",
        "HackerNews"    => "🟠 Hacker News",
        "ProductHunt"   => "🐱 Product Hunt",
        "Video"         => "Videos",
        "Podcast"       => "Podcasts",
        "Article"       => "Articles",
        "Newsletter"    => "Newsletters",
        "ResearchPaper" => "Research",
        "Tool"          => "Tools",
        "Discussion"    => "Discussions",
        _               => Row.ContentType
    };

    private string SourceHref => Row.ContentType switch
    {
        "Reddit"      => "source/reddit",
        "HackerNews"  => "source/hackernews",
        "ProductHunt" => "source/producthunt",
        _             => ""
    };
}
