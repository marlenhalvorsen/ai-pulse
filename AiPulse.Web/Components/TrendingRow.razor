@using AiPulse.Application.DTOs

@if (Row.Items.Any())
{
    <section class="trending-row">
        <h2>@Heading</h2>
        <div class="trending-row__cards">
            @foreach (var item in Row.Items)
            {
                <TrendingCard Item="item" />
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public TrendingRowDto Row { get; set; } = null!;

    private string Heading => Row.ContentType switch
    {
        "Video"        => "Videos",
        "Podcast"      => "Podcasts",
        "Article"      => "Articles",
        "Newsletter"   => "Newsletters",
        "ResearchPaper"=> "Research",
        "Discussion"   => "Discussions",
        _              => Row.ContentType
    };
}
