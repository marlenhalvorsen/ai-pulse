@using AiPulse.Domain.Enums

<nav class="sidebar">
    <div class="sidebar__header">
        <button class="sidebar__toggle" @onclick="ToggleMenu" title="Toggle navigation">
            <span></span><span></span><span></span>
        </button>
    </div>

    <div class="@MenuClass">
        <NavLink class="sidebar__link" href="" Match="NavLinkMatch.All">
            <span class="sidebar__link-icon">⚡</span>Home
        </NavLink>

        <div class="sidebar__section-label">Sources</div>

        @foreach (var source in Enum.GetValues<SourceType>())
        {
            <NavLink class="sidebar__link" href="@($"source/{source.ToString().ToLower()}")">
                <span class="sidebar__link-icon">@SourceIcon(source)</span>@SourceLabel(source)
            </NavLink>
        }
    </div>
</nav>

@code {
    private bool _collapsed = true;

    private string MenuClass => _collapsed ? "sidebar__nav sidebar__nav--collapsed" : "sidebar__nav";

    private void ToggleMenu() => _collapsed = !_collapsed;

    private static string SourceIcon(SourceType source) => source switch
    {
        SourceType.Reddit => "🔴",
        SourceType.HackerNews => "🟠",
        SourceType.ProductHunt => "🐱",
        SourceType.GitHub => "⚫",
        _ => "•"
    };

    private static string SourceLabel(SourceType source) => source switch
    {
        SourceType.Reddit => "Reddit",
        SourceType.HackerNews => "Hacker News",
        SourceType.ProductHunt => "Product Hunt",
        SourceType.DevTo => "Dev.to",
        SourceType.GitHub => "GitHub",
        _ => source.ToString()
    };
}
