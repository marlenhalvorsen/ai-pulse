@page "/"
@using AiPulse.Application.DTOs
@inject HttpClient Http

<PageTitle>AI Pulse — What the AI world is talking about right now</PageTitle>

<SiteLogo />

<p class="page-tagline">AI Pulse tracks what the AI community is actually talking about right now — aggregated from Github, podcasts and product sites, ranked by momentum this week.</p>

@if (_loading)
{
    <p class="loading">Loading trending content…</p>
}
else if (_error is not null)
{
    <p class="error">Could not load trending content. Please try again later.</p>
}
else
{
    <div class="trending-feed">
        @foreach (var row in _rows)
        {
            <TrendingRow Row="row" />
        }
    </div>
}

@code {
    private static readonly string[] RowOrder = ["Reddit", "HackerNews", "GitHub", "ProductHunt", "DevTo", "Tool", "Article", "ResearchPaper", "Video", "Podcast", "Newsletter", "Discussion"];

    private IEnumerable<TrendingRowDto> _rows = [];
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<TrendingResponse>("/api/trending");
            _rows = (response?.Rows ?? [])
                .OrderBy(r => Array.IndexOf(RowOrder, r.ContentType) is var i && i == -1 ? int.MaxValue : i)
                .ToList();
        }
        catch (Exception)
        {
            _error = "Failed to load";
        }
        finally
        {
            _loading = false;
        }
    }
}
